import type { LatLngExpression, MarkerOptions } from 'leaflet'
import type { AstroLeafLetMarkerType, AstroLeafLetOptionsType, AstroLeafLetType, } from './index'

type Props = AstroLeafLetType

const {
  options= {},
  container,
  tileLayer,
  attribution,
  containerstyle = "height: 61.8vh"
} = Astro.props

if (!options.center) {
  options.center = [30, 7]
}
if (!options.markers) {
  options.markers = []
}
if (!options.zoom) {
  options.zoom = 2
}


---

<leaflet-map
  data-container={container}
  data-tiles={tileLayer}
  data-attribution={attribution}
  data-containerstyle={containerstyle}
  data-options={JSON.stringify(options)}
>
<div id={container} style={containerstyle}></div>
</leaflet-map>

<script>
  import L from "leaflet"
  import "leaflet/dist/leaflet.css"

  class LeafletMap extends HTMLElement {
    constructor() {
      super()
      const options = JSON.parse(this.dataset.options!)

      var map = L.map(this.dataset.container).setView(options.center, options.zoom)
      L.tileLayer(
        this.dataset.tiles,
        {attribution: this.dataset.attribution}
        ).addTo(map)

      if (options && options.markers) {
        options.markers.forEach((marker:AstroLeafLetMarkerType) => L.marker(marker.latlng, marker.options).addTo(map))
      }
    }
  }

  window.customElements.define("leaflet-map", LeafletMap);
</script>