---
import LeafLet from '../components/LeafLet.astro';
import type {AstroLeafLetMarkerType, AstroLeafLetOptionsType}  from '../components/index';
import Layout from '../layouts/Layout.astro';

import data from '../data/data.json'

const markers: AstroLeafLetMarkerType[] = []
Object.keys(data).forEach(key => {
	markers.push( {latlng: [data[key].lat, data[key].lon], options: {title: key}} )
})

import CreateLeafLetDivIcon from '../components/CreateLeafLetDivIcon.astro';
import countries from '../data/countries.json'
Object.keys(countries).forEach(key => {
	markers.push( {latlng: [countries[key].lat, countries[key].lon], options: {title: key}, astroIconName:'NAME'} )
})


const options: AstroLeafLetOptionsType = {
	tileLayer: 'https://mt1.google.com/vt/lyrs=m&x={x}&y={y}&z={z}',
	attribution: 'Map data &copy; Google',
	markers: markers,
}


---

<Layout>
	<CreateLeafLetDivIcon name='NAME' class="leaflet-div-icon2"/>
	<LeafLet
		style="width: 100vw; height: 100vh"
		id="leafletid"
		options={options}
	/>
</Layout>

<style is:global>
	/* https://www.drupal.org/docs/extending-drupal/contributed-modules/contributed-module-archive/contrib-modules-for-building-the-site-functionality/geographical-data-and-mapping/leaflet/creating-custom-styles-leaflet-icons-with */
	.leaflet-div-icon2 {
		background:red;
		border:5px solid rgba(255,255,255,0.5);
		color:blue;
		font-weight:bold;
		text-align:center;
		border-radius:50%;
		line-height:30px;
	}
</style>
