---
import { LeafLet, CreateLeafLetDivIcon } from 'astro-leaflet';
import type {AstroLeafLetMarkerType, AstroLeafLetOptionsType}  from 'astro-leaflet';
import Layout from '../layouts/Layout.astro';

import data from '../data/data.json'


import countries from '../data/countries.json'
import visitedCountries from '../data/visited-countries.json'

const markers: AstroLeafLetMarkerType[] = []
Object.keys(data).forEach(key => {
	markers.push( {latlng: [data[key].lat, data[key].lon], options: {title: key}} )
})
// Object.keys(visitedCountries).forEach(key => {
// 	markers.push( {latlng: [visitedCountries[key].lat, visitedCountries[key].lon], options: {title: key}} )
// })
Object.keys(countries).forEach(key => {
	if (visitedCountries[key] === undefined) {
		markers.push( {latlng: [countries[key].lat, countries[key].lon], options: {title: key}, astroIconName:'icon-missingcountries'} )
	}
})


const options: AstroLeafLetOptionsType = {
	tileLayer: 'https://mt1.google.com/vt/lyrs=m&x={x}&y={y}&z={z}',
	attribution: 'Map data &copy; Google',
	markers: markers,
}



---

<Layout>
		<CreateLeafLetDivIcon name='icon-missingcountries' class="leaflet-icon-missingcountries"/>
	<LeafLet
		style="width: 100vw; height: 100vh"
		options={options}
	>
	</LeafLet>
</Layout>

<style is:global>
	/* creating an icon.
	   cf. for some examples
		   https://www.drupal.org/docs/extending-drupal/contributed-modules/contributed-module-archive/contrib-modules-for-building-the-site-functionality/geographical-data-and-mapping/leaflet/creating-custom-styles-leaflet-icons-with */
	.leaflet-icon-missingcountries {
		background:red;
		border:5px solid rgba(255,255,255,0.5);
		color:blue;
		font-weight:bold;
		text-align:center;
		border-radius:50%;
		line-height:30px;
	}
</style>
